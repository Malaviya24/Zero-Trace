# Frontend runtime target (set this to your production Convex deployment in hosting)
VITE_CONVEX_URL=https://your-production-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-production-deployment.convex.site
# No auth secrets are required for the frontend.

# Optional WebRTC defaults
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Required for production call reliability across regions/NATs
# Comma-separated TURN urls, e.g. turn:turn.yourdomain.com:3478,turns:turn.yourdomain.com:5349?transport=tcp
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Required for production SFU media transport
# Example: wss://your-project.livekit.cloud
VITE_SFU_URL=
